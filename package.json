{
  "name": "azx-cli",
  "version": "0.1.0",
  "description": "Agent-First CLI for AZX DEX (Spot + Futures)",
  "type": "module",
  "bin": {
    "azx": "./bin/azx.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node bin/azx.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["azx", "dex", "cli", "trading", "spot", "futures"],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "cli-table3": "^0.6.5",
    "conf": "^13.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
